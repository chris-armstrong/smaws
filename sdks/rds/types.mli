        \ Constraints:\n\
        \ \n\
        \  {ul\n\
        \        {-  Can't be specified if the [RestoreTime] parameter is provided.\n\
        \            \n\
        \             }\n\
        \        }\n\
        \  "]
  db_instance_class : string_ option;
