type nonrec account_quota = {
  account_quota_name : string_ option;
      [@ocaml.doc "The name of the Amazon RDS quota for this Amazon Web Services account.\n"]
  used : long option; [@ocaml.doc "The amount currently used toward the quota maximum.\n"]
  max : long option; [@ocaml.doc "The maximum allowed value for the quota.\n"]
}
[@@ocaml.doc
  "Describes a quota for an Amazon Web Services account.\n\n\
  \ The following are account quotas:\n\
  \ \n\
  \  {ul\n\
  \        {-   [AllocatedStorage] - The total allocated storage per account, in GiB. The used \
   value is the total allocated storage in the account, in GiB.\n\
  \            \n\
  \             }\n\
  \        {-   [AuthorizationsPerDBSecurityGroup] - The number of ingress rules per DB security \
   group. The used value is the highest number of ingress rules in a DB security group in the \
   account. Other DB security groups in the account might have a lower number of ingress rules.\n\
  \            \n\
  \             }\n\
  \        {-   [CustomEndpointsPerDBCluster] - The number of custom endpoints per DB cluster. The \
   used value is the highest number of custom endpoints in a DB clusters in the account. Other DB \
   clusters in the account might have a lower number of custom endpoints.\n\
  \            \n\
  \             }\n\
  \        {-   [DBClusterParameterGroups] - The number of DB cluster parameter groups per \
   account, excluding default parameter groups. The used value is the count of nondefault DB \
   cluster parameter groups in the account.\n\
  \            \n\
  \             }\n\
  \        {-   [DBClusterRoles] - The number of associated Amazon Web Services Identity and \
   Access Management (IAM) roles per DB cluster. The used value is the highest number of \
   associated IAM roles for a DB cluster in the account. Other DB clusters in the account might \
   have a lower number of associated IAM roles.\n\
  \            \n\
  \             }\n\
  \        {-   [DBClusters] - The number of DB clusters per account. The used value is the count \
   of DB clusters in the account.\n\
  \            \n\
  \             }\n\
  \        {-   [DBInstanceRoles] - The number of associated IAM roles per DB instance. The used \
   value is the highest number of associated IAM roles for a DB instance in the account. Other DB \
   instances in the account might have a lower number of associated IAM roles.\n\
  \            \n\
  \             }\n\
  \        {-   [DBInstances] - The number of DB instances per account. The used value is the \
   count of the DB instances in the account.\n\
  \            \n\
  \             Amazon RDS DB instances, Amazon Aurora DB instances, Amazon Neptune instances, and \
   Amazon DocumentDB instances apply to this quota.\n\
  \             \n\
  \              }\n\
  \        {-   [DBParameterGroups] - The number of DB parameter groups per account, excluding \
   default parameter groups. The used value is the count of nondefault DB parameter groups in the \
   account.\n\
  \            \n\
  \             }\n\
  \        {-   [DBSecurityGroups] - The number of DB security groups (not VPC security groups) \
   per account, excluding the default security group. The used value is the count of nondefault DB \
   security groups in the account.\n\
  \            \n\
  \             }\n\
  \        {-   [DBSubnetGroups] - The number of DB subnet groups per account. The used value is \
   the count of the DB subnet groups in the account.\n\
  \            \n\
  \             }\n\
  \        {-   [EventSubscriptions] - The number of event subscriptions per account. The used \
   value is the count of the event subscriptions in the account.\n\
  \            \n\
  \             }\n\
  \        {-   [ManualClusterSnapshots] - The number of manual DB cluster snapshots per account. \
   The used value is the count of the manual DB cluster snapshots in the account.\n\
  \            \n\
  \             }\n\
  \        {-   [ManualSnapshots] - The number of manual DB instance snapshots per account. The \
   used value is the count of the manual DB instance snapshots in the account.\n\
  \            \n\
  \             }\n\
  \        {-   [OptionGroups] - The number of DB option groups per account, excluding default \
   option groups. The used value is the count of nondefault DB option groups in the account.\n\
  \            \n\
  \             }\n\
  \        {-   [ReadReplicasPerMaster] - The number of read replicas per DB instance. The used \
   value is the highest number of read replicas for a DB instance in the account. Other DB \
   instances in the account might have a lower number of read replicas.\n\
  \            \n\
  \             }\n\
  \        {-   [ReservedDBInstances] - The number of reserved DB instances per account. The used \
   value is the count of the active reserved DB instances in the account.\n\
  \            \n\
  \             }\n\
  \        {-   [SubnetsPerDBSubnetGroup] - The number of subnets per DB subnet group. The used \
   value is highest number of subnets for a DB subnet group in the account. Other DB subnet groups \
   in the account might have a lower number of subnets.\n\
  \            \n\
  \             }\n\
  \        }\n\
  \   For more information, see \
   {{:https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/CHAP_Limits.html}Quotas for Amazon \
   RDS} in the {i Amazon RDS User Guide} and \
   {{:https://docs.aws.amazon.com/AmazonRDS/latest/AuroraUserGuide/CHAP_Limits.html}Quotas for \
   Amazon Aurora} in the {i Amazon Aurora User Guide}.\n\
  \   "]

