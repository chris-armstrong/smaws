         Services Region.\n\
        \  "]
  performance_insights_retention_period : integer_optional option;
      [@ocaml.doc
        "The number of days to retain Performance Insights data. The default is 7 days. The \
         following values are valid:\n\n\
        \ {ul\n\
        \       {-  7\n\
        \           \n\
        \            }\n\
