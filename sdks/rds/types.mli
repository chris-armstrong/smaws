      [@ocaml.doc
        "The network type of the DB cluster.\n\n\
        \ Valid Values:\n\
        \ \n\
        \  {ul\n\
        \        {-   [IPV4] \n\
        \            \n\
        \             }\n\
        \        {-   [DUAL] \n\
        \            \n\
        \             }\n\
