type nonrec restore_db_instance_to_point_in_time_message = {
  source_db_instance_identifier : string_ option;
      [@ocaml.doc
        "The identifier of the source DB instance from which to restore.\n\n\
        \ Constraints:\n\
        \ \n\
        \  {ul\n\
        \        {-  Must match the identifier of an existing DB instance.\n\
        \            \n\
        \             }\n\
        \        }\n\
        \  "]
  target_db_instance_identifier : string_;
      [@ocaml.doc
        "The name of the new DB instance to create.\n\n\
        \ Constraints:\n\
        \ \n\
        \  {ul\n\
        \        {-  Must contain from 1 to 63 letters, numbers, or hyphens.\n\
        \            \n\
        \             }\n\
        \        {-  First character must be a letter.\n\
        \            \n\
        \             }\n\
        \        {-  Can't end with a hyphen or contain two consecutive hyphens.\n\
        \            \n\
        \             }\n\
        \        }\n\
        \  "]
  restore_time : t_stamp option;
      [@ocaml.doc
