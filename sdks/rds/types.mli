         User Guide}.\n\
        \ "]
  backup_target : string_ option;
      [@ocaml.doc
        "The location where RDS stores automated backups and manual snapshots.\n\n\
        \ Valid Values:\n\
        \ \n\
        \  {ul\n\
        \        {-   [local] for Dedicated Local Zones\n\
