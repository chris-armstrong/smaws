        \  \n\
        \   Valid Values:\n\
        \   \n\
        \    {ul\n\
        \          {-   [IPV4] \n\
        \              \n\
        \               }\n\
        \          {-   [DUAL] \n\
        \              \n\
        \               }\n\
        \          }\n\
        \  "]
  source_db_instance_automated_backups_arn : string_ option;
      [@ocaml.doc
        "The Amazon Resource Name (ARN) of the replicated automated backups from which to restore, \
         for example, \
         [arn:aws:rds:us-east-1:123456789012:auto-backup:ab-L2IJCEXJP7XQ7HOJ4SIEXAMPLE].\n\n\
        \ This setting doesn't apply to RDS Custom.\n\
        \ "]
  backup_target : string_ option;
      [@ocaml.doc
        "The location for storing automated backups and manual snapshots for the restored DB \
         instance.\n\n\
        \ Valid Values:\n\
        \ \n\
        \  {ul\n\
        \        {-   [local] (Dedicated Local Zone)\n\
        \            \n\
        \             }\n\
        \        {-   [outposts] (Amazon Web Services Outposts)\n\
