        \               {-   [oracle-se2-cdb] \n\
        \                   \n\
        \                    }\n\
        \               {-   [postgres] \n\
        \                   \n\
        \                    }\n\
        \               {-   [sqlserver-ee] \n\
        \                   \n\
        \                    }\n\
        \               {-   [sqlserver-se] \n\
        \                   \n\
        \                    }\n\
        \               {-   [sqlserver-ex] \n\
        \                   \n\
        \                    }\n\
        \               {-   [sqlserver-web] \n\
        \                   \n\
        \                    }\n\
        \               }\n\
        \  "]
  description : string_; [@ocaml.doc "The description for the DB parameter group.\n"]
  tags : tag_list option; [@ocaml.doc "Tags to assign to the DB parameter group.\n"]
}
