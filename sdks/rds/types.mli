type nonrec db_engine_version = {
  engine : string_ option; [@ocaml.doc "The name of the database engine.\n"]
  major_engine_version : string_ option; [@ocaml.doc "The major engine version of the CEV.\n"]
  engine_version : string_ option; [@ocaml.doc "The version number of the database engine.\n"]
  database_installation_files_s3_bucket_name : string_ option;
      [@ocaml.doc
        "The name of the Amazon S3 bucket that contains your database installation files.\n"]
  database_installation_files_s3_prefix : string_ option;
      [@ocaml.doc
        "The Amazon S3 directory that contains the database installation files. If not specified, \
         then no prefix is assumed.\n"]
  database_installation_files : string_list option;
      [@ocaml.doc
        "The database installation files (ISO and EXE) that were uploaded to Amazon S3 and used to \
         import the database engine version to Amazon RDS. Returned for RDS for SQL Server engine \
         versions ([sqlserver-ee], [sqlserver-se], and [sqlserver-dev-ee]) created from \
         customer-supplied installation media.\n"]
