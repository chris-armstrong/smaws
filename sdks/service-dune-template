(rule
 (deps
  (:gen ../../bin/AwsGenerator.exe)
  (:input %%model-file%%)
  (:ocf %{bin:ocamlformat}))
 (targets
  builders.ml
  builders.mli
  %%serializer-module%%.ml
  %%deserializer-module%%.ml
  service_metadata.ml
  service_metadata.mli
  types.ml
  types.mli
  operations.ml
  operations.mli
  Smaws_Client_%%service-full-name%%.ml
  Smaws_Client_%%service-full-name%%.mli)
 (mode promote)
 (action
  (progn
   (run
    %{gen}
    -input
    %{input}
    -output
    .
    -targets
    builders
    types
    service_metadata
    serializers
    deserializers
    operations
    module)
   (run
    %{ocf}
    -i
    builders.ml
    builders.mli
    %%serializer-module%%.ml
    %%deserializer-module%%.ml
    service_metadata.ml
    service_metadata.mli
    types.ml
    types.mli
    operations.ml
    operations.mli
    Smaws_Client_%%service-full-name%%.ml
    Smaws_Client_%%service-full-name%%.mli))))

(library
 (name Smaws_Client_%%service-full-name%%)
 (public_name smaws-clients.%%service-short-name%%)
 (modules
  Smaws_Client_%%service-full-name%%
  types
  service_metadata
  %%serializer-module%%
  %%deserializer-module%%
  operations
  builders)
 (libraries smaws-lib))